{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal OS",
  "version": "1.0.0-beta",
  "identifier": "com.hadi.personal-os",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Personal OS",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "© 2026 Hadi. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Your personal operating system for tasks, notes, links and projects.",
    "longDescription": "Personal OS is a local-first desktop app for managing todos, notes, saved links, work logs and project timelines — with optional cloud sync.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
